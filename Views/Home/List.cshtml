@model List<Product>
@section Styles{
   <link rel="stylesheet" href="~/css/styles.css">
    
}

    <section class="product-listing py-5">
        <div class="container">
            <div class="row">
                <aside class="col-md-3 mb-5">
                    <div class="filter-section">
                        <h4 class="category-title border-bottom pb-2 mb-4">KATEGORİLER</h4>
                        <ul class="list-unstyled category-list">
                            <li><a href="#" class="active">Tüm Saatler</a></li>
                            <li><a href="#">Tank de Cartier</a></li>
                            <li><a href="#">Santos de Cartier</a></li>
                            <li><a href="#">Panthère de Cartier</a></li>
                            <li><a href="#">Ballon Bleu</a></li>
                            <li><a href="#">Pasha de Cartier</a></li>
                        </ul>

                        <h4 class="category-title border-bottom pb-2 mt-5 mb-4">MATERYAL</h4>
                        <ul class="list-unstyled category-list">
                            <li><a href="#">Sarı Altın</a></li>
                            <li><a href="#">Pembe Altın</a></li>
                            <li><a href="#">Çelik</a></li>
                            <li><a href="#">Deri Kayış</a></li>
                        </ul>
                    </div>
                </aside>

                <main class="col-md-9">
                    <div class="row g-4">
                        @foreach(var product in Model)
                        {
                            <div class="col-md-4 text-center product-card">
                            <div class="product-img-wrapper">
                                <img src="~/img/@product.Image" class="img-fluid" alt="Saat">
                            </div>
                            <h5 class="product-title mt-3">@product.Title</h5>
                            <p class="text-muted extra-small">@product.Description</p>
                            <p class="price">TRY @product.Price</p>
                        </div>
                        }
                    </div>

                    <nav class="mt-5 pt-4">
                        <ul class="pagination justify-content-center luxury-pagination">
                            <li class="page-item disabled"><a class="page-link" href="#">Geri</a></li>
                            <li class="page-item active"><a class="page-link" href="#">1</a></li>
                            <li class="page-item"><a class="page-link" href="#">2</a></li>
                            <li class="page-item"><a class="page-link" href="#">3</a></li>
                            <li class="page-item"><a class="page-link" href="#">İleri</a></li>
                        </ul>
                    </nav>
                </main>
            </div>
        </div>
    </section>