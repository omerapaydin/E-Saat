@model IEnumerable<Product>

    <section class="hero-section">
        <div class="hero-visual"></div>
        
        <div class="hero-overlay-content">
            <h2 class="serif-font display-4 reveal-text">WATCHES AND WONDERS 2026</h2>
            <p class="lead tracking-widest reveal-text-delayed">Cartier saat koleksiyonundaki en son yenilikleri keşfedin.</p>
            <div class="mt-4">
                <a href="#" class="btn-luxury">DENEYİMİ KEŞFEDİN</a>
            </div>
        </div>
    </section>

    <section class="products py-5 bg-white">
        <div class="container">
            <div class="row g-4">
            @foreach (var product in Model)
            {    
                <div class="col-6 col-md-3 text-center product-card">
                    <div class="product-img-wrapper">
                        <img src="~/img/@product.Image" class="img-fluid mb-3" alt="@product.Title">
                    </div>
                    <h5 class="product-title">@product.Title</h5>
                    <p class="text-muted extra-small">@product.Description</p>
                    <p class="price">TRY @product.Price</p>
                </div>
            }
            </div>
        </div>
    </section>

    <section class="collections py-5">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-6 text-center">
                    <div class="overflow-hidden mb-3">
                        <img src="https://images.unsplash.com/photo-1523170335258-f5ed11844a49?q=80&w=2070" class="img-fluid hover-zoom" alt="Tank">
                    </div>
                    <h3 class="h4 tracking-widest">TANK</h3>
                    <p class="small text-muted">Olağanüstü forma ve tasarıma sahip bir saat.</p>
                    <a href="#" class="btn-link">Keşfedin</a>
                </div>
                <div class="col-md-6 text-center">
                    <div class="overflow-hidden mb-3">
                        <img src="https://images.unsplash.com/photo-1547996160-81dfa63595aa?q=80&w=2070" class="img-fluid hover-zoom" alt="Panthere">
                    </div>
                    <h3 class="h4 tracking-widest">PANTHÈRE DE CARTIER</h3>
                    <p class="small text-muted">Vahşi cazibesini konuşturuyor.</p>
                    <a href="#" class="btn-link">Keşfedin</a>
                </div>
            </div>
        </div>
    </section>

  