<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Saat | Premium Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
</head>
<body>

    <nav class="navbar navbar-expand-lg fixed-top shadow-sm" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="#">Saat§</a>
            <div class="d-flex align-items-center order-lg-3">
                <a href="#" class="text-dark me-4 position-relative">
                    <i class="fa-solid fa-bag-shopping fs-4"></i>
                    <span id="cart-count" class="badge bg-dark rounded-circle">0</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav mx-auto text-uppercase small fw-semibold">
                    <li class="nav-item"><a class="nav-link px-3" href="#">Koleksiyon</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="#">Yeni Gelenler</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="#">Hakkımızda</a></li>
                </ul>
            </div>
        </div>
    </nav>

    @RenderBody()

   

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/bundle/min.js"></script>
   <script src="~/js/script.js" asp-append-version="true"></script>
</body>
</html>