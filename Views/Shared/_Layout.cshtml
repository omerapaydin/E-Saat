<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lüks Saat Tasarımı | Cartier Concept</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
   <link rel="stylesheet" asp-append-version="true" href="~/css/style.css" />
    @RenderSection("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom fixed-top" id="mainNavbar">
        <div class="container d-flex align-items-center justify-content-between">

            <!-- LOGO -->
            <a class="navbar-brand logo-font" href="/Home/Index">Cartier</a>

            <!-- NAV LINKS -->
            <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                <ul class="navbar-nav text-uppercase small tracking-widest gap-lg-4">
                    <li class="nav-item"><a class="nav-link" href="#">Yüksek Mücevher</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Mücevher</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/List">Saatler</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Çantalar ve Aksesuarlar</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Parfümler</a></li>
                </ul>
            </div>

            <!-- SAĞ TARAF ICONLAR -->
            <div class="nav-icons d-flex align-items-center gap-3">
                <a href="/Account/Login" title="Giriş">
                    <i class="bi bi-person"></i>
                </a>
                <a href="/Account/Register" title="Üye Ol">
                    <i class="bi bi-person-plus"></i>
                </a>
                <a href="/Account/Logout" title="Çıkış">
                    <i class="bi bi-box-arrow-right"></i>
                </a>
            </div>

            <!-- MOBILE TOGGLER -->
            <button class="navbar-toggler ms-2" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

        </div>
    </nav>

    <div class="cont-1">
          @RenderBody()
        <footer class="luxury-footer">

            <div class="container">

                

                <div class="row gy-5">

                    <!-- Marka -->

                    <div class="col-lg-4 text-center text-lg-start">

                        <h2 class="footer-logo serif-font">Cartier</h2>

                        <p class="footer-desc">

                            Saatçilik sanatında kusursuz işçilik ve zamansız estetik.

                        </p>

                    </div>

                    <!-- Menü -->

                    <div class="col-6 col-lg-2">

                        <h6 class="footer-title">KOLEKSİYONLAR</h6>

                        <ul class="footer-links">

                            <li><a href="#">Tank</a></li>

                            <li><a href="#">Santos</a></li>

                            <li><a href="#">Panthère</a></li>

                            <li><a href="#">Ballon Bleu</a></li>

                        </ul>

                    </div>

                    <!-- Hizmet -->

                    <div class="col-6 col-lg-2">

                        <h6 class="footer-title">HİZMETLER</h6>

                        <ul class="footer-links">

                            <li><a href="#">Destek</a></li>

                            <li><a href="#">Bakım</a></li>

                            <li><a href="#">Garanti</a></li>

                            <li><a href="#">İletişim</a></li>

                        </ul>

                    </div>

                    <!-- Newsletter -->

                    <div class="col-lg-4">

                        <h6 class="footer-title">BÜLTENE KATILIN</h6>

                        <p class="footer-desc mb-4">

                            Cartier dünyasındaki yeni koleksiyonlar ve özel içerikler için kayıt olun.

                        </p>

                        <form class="newsletter-form">

                            <input type="email" placeholder="E-mail adresiniz">

                            <button type="submit">KATIL</button>

                        </form>

                    </div>

                </div>

                <div class="footer-bottom">

                    <p>© 2026 Cartier Inspired Design. All rights reserved.</p>

                </div>

            </div>

        </footer>
    </div>

    <script>
    window.addEventListener("scroll", function () {
        const navbar = document.getElementById("mainNavbar");

        if (window.scrollY > 80) {
            navbar.classList.add("nav-hidden");
        } else {
            navbar.classList.remove("nav-hidden");
        }
    });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>